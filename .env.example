# Stripe — create a restricted API key in Dashboard → Developers → API keys
STRIPE_SECRET_KEY=

# Product catalogue → deposit product → Price ID (starts with price_)
STRIPE_DEPOSIT_PRICE_ID=

# Optional: used as fallback if Origin is missing (e.g. some proxies)
NEXT_PUBLIC_SITE_URL=

# --- Google Sheets (optional final submit only; drafts stay server logs only) ---
# 1) Google Cloud → APIs → enable "Google Sheets API"
# 2) IAM → Service accounts → create key (JSON). Copy the service account email.
# 3) Open your Sheet → Share → give that email Editor access
# 4) Spreadsheet ID = the long id in the Sheet URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=
# Worksheet tab name (creates new rows here). Default if unset: Onboarding
# GOOGLE_SHEETS_TAB_NAME=Onboarding
# Easiest locally: save the downloaded key as google-sheets-service-account.json (gitignored) and set:
GOOGLE_APPLICATION_CREDENTIALS=google-sheets-service-account.json
# Or: GOOGLE_SERVICE_ACCOUNT_KEY_FILE=google-sheets-service-account.json
# Or Vercel: GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
# Or .env one-liner only: GOOGLE_SERVICE_ACCOUNT_JSON=
# Header row: npm run sync:sheet-headers (or ONBOARDING_SHEET_HEADERS in lib/onboarding-sheet-headers.ts)
